# Copy this file to .env.local and fill in real values.
# For Vercel: add the same variables in Project Settings > Environment Variables.

# Google Sheets spreadsheet that stores the reports
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# Google Cloud service account (IAM & Admin > Service Accounts > Keys > JSON)
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Keep the quotes; use \n for line breaks in the key
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Password required to access the Head Office branch
HEAD_OFFICE_PASSWORD=choose-a-strong-password

# Optional: password for the MCTI Tasliya branch (leave unset to keep it open)
# MCTI_PASSWORD=another-strong-password

# Optional: secret used to sign session cookies
# (falls back to HEAD_OFFICE_PASSWORD if unset)
# APP_SECRET=any-long-random-string
